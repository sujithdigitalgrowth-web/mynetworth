# Copy this to .env.local for local testing with GitHub mode
# On Railway, set these as environment variables in the dashboard

# Your admin login password (change this!)
ADMIN_PASSWORD=worthscale2026

# GitHub Personal Access Token (repo scope)
# Get it at: https://github.com/settings/tokens → Generate new token (classic) → tick "repo"
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# GitHub repo details (already correct for your setup)
GITHUB_OWNER=sujithdigitalgrowth-web
GITHUB_REPO=mynetworth

# Railway sets PORT automatically — do not set this yourself
# PORT=4000
